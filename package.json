{
  "name": "express-typescript-starter-template",
  "version": "1.0.0",
  "description": "A production-ready Express TypeScript starter template",
  "main": "dist/server.js",
  "scripts": {
    "dev": "DOTENV_CONFIG_QUIET=true DOTENVX_QUIET=true node --import tsx --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prepare": "husky",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:reset": "docker compose down -v && docker compose up -d --build",
    "docker:logs": "docker compose logs -f"
  },
  "keywords": [
    "express",
    "typescript",
    "starter",
    "template",
    "node",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "mongoose": "^9.7.4",
    "morgan": "^1.11.0",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write"
    ],
    "*.{ts,js}": [
      "eslint"
    ]
  }
}
